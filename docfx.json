{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "build": {
    "content": [
      {
        "src": "docs",
        "files": [
          "**/*.md",
          "**/toc.yml"
        ],
        "exclude": [
          "internal/**",
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "src": "docs",
        "files": [
          "assets/**"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "output": "docs/_site",
    "template": [
      "default",
      "modern",
      "docfx/templates/nacelle"
    ],
    "globalMetadata": {
      "_appName": "nacelle",
      "_appTitle": "nacelle docs",
      "_appLogoPath": "assets/nacelle-mark.svg",
      "_appFaviconPath": "assets/nacelle-mark.svg",
      "_appFooter": "nacelle documentation. Built with DocFX.",
      "_disableContribution": true,
      "_enableSearch": true,
      "_description": "Documentation for Nacelle, an experimental Tokio-based Rust library for streaming application handlers across multiple transports."
    }
  }
}
